{
  "name": "webmcp-userscripts",
  "version": "1.0.0",
  "description": "TypeScript monorepo for building and testing Tampermonkey scripts which give websites WebMCP capabilities",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:legacy": "tsx tools/build-all.ts",
    "test": "tsx tools/test-runner.ts",
    "test:runner": "tsx tools/test-runner.ts",
    "test:gmail": "tsx tools/test-runner.ts --script gmail",
    "test:headless": "tsx tools/test-runner.ts --headless",
    "dev": "turbo run dev",
    "dev:gmail": "turbo run dev --filter=@webmcp-userscripts/gmail-injector",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "lint:fix": "biome lint --apply .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --apply .",
    "clean": "turbo run clean",
    "install:all": "pnpm install && pnpm -r install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.5.3",
    "@types/node": "^20.11.30",
    "@types/puppeteer": "^5.4.7",
    "puppeteer": "^22.5.0",
    "tsx": "^4.7.1",
    "turbo": "^2.5.6",
    "typescript": "^5.4.3"
  },
  "packageManager": "pnpm@10.12.1"
}
